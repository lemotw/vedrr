                      "fill": "$accent-success",
                      "content": "const verifyToken = (req, res, next) => {",
                      "fontFamily": "JetBrains Mono",
                      "fontSize": 11,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "rsqR0",
                      "name": "edCodeL2",
                      "fill": "$accent-success",
                      "content": "  const token = req.headers.authorization;",
                      "fontFamily": "JetBrains Mono",
